# =============================================================================
# DYNAMIC FORMS
# =============================================================================

class DynamicForm(forms.ModelForm):
    """
    Form with dynamic field generation.
    """

    class Meta:
        model = YourModel
        fields = ['name', 'description']

    def __init__(self, *args, **kwargs):
        """Customize form based on parameters."""
        user = kwargs.pop('user', None)  # Get custom parameter
        super().__init__(*args, **kwargs)

        # Example: Make field required based on user
        if user and not user.is_staff:
            self.fields['description'].required = True

        # Example: Modify field widget
        self.fields['name'].widget.attrs.update({
            'class': 'form-control',
            'placeholder': 'Enter name'
        })

        # Example: Add field dynamically
        self.fields['extra_field'] = forms.CharField(
            required=False,
            label='Extra Information'
        )

        # Example: Remove field conditionally
        if not user or not user.is_staff:
            self.fields.pop('description', None)


# =============================================================================
# FORM VALIDATION HELPERS
# =============================================================================

def validate_file_extension(value):
    """
    Custom validator for file extensions.
    Use in field: validators=[validate_file_extension]
    """
    import os
    ext = os.path.splitext(value.name)[1]
    valid_extensions = ['.pdf', '.doc', '.docx']
    if not ext.lower() in valid_extensions:
        raise ValidationError('Unsupported file extension.')


def validate_phone_number(value):
    """
    Custom validator for phone numbers.
    """
    import re
    phone_regex = re.compile(r'^\+?1?\d{9,15}$')
    if not phone_regex.match(value):
        raise ValidationError('Invalid phone number format.')


