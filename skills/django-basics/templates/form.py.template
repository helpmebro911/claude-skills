# REGULAR FORM (Not tied to a model)
# =============================================================================

class ContactForm(forms.Form):
    """
    Regular form not tied to a model.
    Use when: Contact forms, search forms, custom logic.
    """
    name = forms.CharField(
        max_length=100,
        required=True,
        label='Your Name',
        widget=forms.TextInput(attrs={
            'class': 'form-control',
            'placeholder': 'John Doe'
        })
    )

    email = forms.EmailField(
        required=True,
        label='Email Address',
        widget=forms.EmailInput(attrs={
            'class': 'form-control',
            'placeholder': 'john@example.com'
        })
    )

    message = forms.CharField(
        required=True,
        label='Your Message',
        widget=forms.Textarea(attrs={
            'class': 'form-control',
            'rows': 5,
            'placeholder': 'Enter your message...'
        })
    )

    subscribe = forms.BooleanField(
        required=False,
        label='Subscribe to newsletter',
        widget=forms.CheckboxInput(attrs={
            'class': 'form-check-input'
        })
    )

    def clean_email(self):
        """Validate email domain."""
        email = self.cleaned_data.get('email')

        # Example: Only allow certain domains
        allowed_domains = ['example.com', 'test.com']
        domain = email.split('@')[1] if '@' in email else ''

        if domain not in allowed_domains:
            raise ValidationError(f'Please use an email from: {", ".join(allowed_domains)}')

        return email

    def send_email(self):
        """Process the form data."""
        if not self.is_valid():
            return False

        from django.core.mail import send_mail

        send_mail(
            subject=f'Contact from {self.cleaned_data["name"]}',
            message=self.cleaned_data['message'],
            from_email=self.cleaned_data['email'],
            recipient_list=['admin@example.com'],
        )

        return True


