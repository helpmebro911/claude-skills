from django import forms
from django.core.exceptions import ValidationError
from .models import YourModel


# =============================================================================
# MODELFORM (Most Common)
# =============================================================================

class YourModelForm(forms.ModelForm):
    """
    Form based on a Django model.
    Use when: Creating/editing model instances.
    """

    class Meta:
        model = YourModel
        fields = ['name', 'description', 'is_active']  # Explicit fields
        # fields = '__all__'  # All fields (not recommended)
        # exclude = ['created_at', 'author']  # Exclude specific fields

        # Custom labels
        labels = {
            'name': 'Item Name',
            'description': 'Detailed Description',
        }

        # Help text
        help_texts = {
            'name': 'Enter a unique name for this item.',
        }

        # Custom widgets
        widgets = {
            'name': forms.TextInput(attrs={
                'class': 'form-control',
                'placeholder': 'Enter name...'
            }),
            'description': forms.Textarea(attrs={
                'class': 'form-control',
                'rows': 5,
                'placeholder': 'Enter description...'
            }),
            'is_active': forms.CheckboxInput(attrs={
                'class': 'form-check-input'
            }),
        }

    # Field-level validation
    def clean_name(self):
        """Validate the name field."""
        name = self.cleaned_data.get('name')

        # Example validation
        if len(name) < 3:
            raise ValidationError('Name must be at least 3 characters long.')

        # Check for uniqueness (case-insensitive)
        if YourModel.objects.filter(name__iexact=name).exists():
            # Exclude current instance when editing
            if self.instance.pk:
                if YourModel.objects.filter(name__iexact=name).exclude(pk=self.instance.pk).exists():
                    raise ValidationError('This name is already taken.')
            else:
                raise ValidationError('This name is already taken.')

        return name

    # Form-level validation
    def clean(self):
        """Validate multiple fields together."""
        cleaned_data = super().clean()
        name = cleaned_data.get('name')
        description = cleaned_data.get('description')

        # Example: Cross-field validation
        if name and description:
            if name.lower() in description.lower():
                raise ValidationError('Description should not contain the name.')

        return cleaned_data

    def save(self, commit=True):
        """Override save to add custom logic."""
        instance = super().save(commit=False)

        # Example: Auto-generate slug
        from django.utils.text import slugify
        if not instance.slug:
            instance.slug = slugify(instance.name)

        if commit:
            instance.save()
            # Save many-to-many fields if using commit=False
            self.save_m2m()

        return instance


