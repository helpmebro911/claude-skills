from django.views import View
from django.utils.decorators import method_decorator
from django.views.decorators.http import require_http_methods


class CustomView(View):
    """
    Custom view with multiple HTTP methods.
    Use when: Need full control over HTTP method handling.
    """
    @method_decorator(login_required)
    def dispatch(self, *args, **kwargs):
        """Add login requirement to all methods."""
        return super().dispatch(*args, **kwargs)

    def get(self, request, *args, **kwargs):
        """Handle GET requests."""
        context = {'message': 'GET request'}
        return render(request, 'yourapp/custom.html', context)

    def post(self, request, *args, **kwargs):
        """Handle POST requests."""
        # Process form data
        return redirect('yourapp:index')


@require_http_methods(["GET", "POST"])
def restricted_methods_view(request):
    """
    View that only accepts specific HTTP methods.
    Use when: Need to restrict allowed HTTP methods.
    """
    if request.method == 'POST':
        # Handle POST
        pass
    # Handle GET
    return render(request, 'yourapp/template.html')


# Multiple forms in one view
def multi_form_view(request):
    """
    View with multiple forms.
    Use when: Need to handle multiple forms on one page.
    """
    from .forms import Form1, Form2

    if request.method == 'POST':
        form1 = Form1(request.POST, prefix='form1')
        form2 = Form2(request.POST, prefix='form2')

        if form1.is_valid() and form2.is_valid():
            form1.save()
            form2.save()
            return redirect('success')
    else:
        form1 = Form1(prefix='form1')
        form2 = Form2(prefix='form2')

    context = {'form1': form1, 'form2': form2}
    return render(request, 'yourapp/multi_form.html', context)


# =============================================================================
# MIXINS FOR CLASS-BASED VIEWS
# =============================================================================

from django.core.exceptions import PermissionDenied


class AuthorRequiredMixin:
    """
    Mixin to ensure user is the author of the object.
    Use with UpdateView, DeleteView.
    """
    def get_object(self, *args, **kwargs):
        obj = super().get_object(*args, **kwargs)
        if obj.author != self.request.user:
            raise PermissionDenied
        return obj


class TitleMixin:
    """
    Mixin to add page title to context.
    """
    title = None

    def get_context_data(self, **kwargs):
        context = super().get_context_data(**kwargs)
        context['title'] = self.title or self.model._meta.verbose_name_plural
        return context


# Example using mixins
class MyUpdateView(LoginRequiredMixin, AuthorRequiredMixin, TitleMixin, UpdateView):
    model = YourModel
    form_class = YourModelForm
    template_name = 'yourapp/form.html'
    title = 'Edit Item'


