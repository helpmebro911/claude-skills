from django import forms


class YourModelAdminForm(forms.ModelForm):
    """
    Custom form for admin.
    Use when: Need custom validation or widgets in admin.
    """

    class Meta:
        model = YourModel
        fields = '__all__'
        widgets = {
            'description': forms.Textarea(attrs={'rows': 10}),
        }

    def clean_name(self):
        """Custom validation."""
        name = self.cleaned_data.get('name')
        if 'forbidden' in name.lower():
            raise forms.ValidationError('Name contains forbidden words.')
        return name


@admin.register(YourModel)
class YourModelWithFormAdmin(admin.ModelAdmin):
    """Admin using custom form."""
    form = YourModelAdminForm


