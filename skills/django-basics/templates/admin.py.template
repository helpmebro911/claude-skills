@admin.register(YourModel)
class AdvancedYourModelAdmin(admin.ModelAdmin):
    """
    Advanced admin with all features.
    """

    # Custom list view template
    change_list_template = 'admin/yourapp/yourmodel_change_list.html'

    # Custom detail view template
    # change_form_template = 'admin/yourapp/yourmodel_change_form.html'

    # Permissions
    def has_delete_permission(self, request, obj=None):
        """Only superusers can delete."""
        return request.user.is_superuser

    def has_change_permission(self, request, obj=None):
        """Users can only edit their own items."""
        if obj is not None and not request.user.is_superuser:
            return obj.author == request.user
        return True

    # Custom filters
    def get_list_filter(self, request):
        """Customize filters based on user."""
        filters = super().get_list_filter(request)
        if request.user.is_superuser:
            return filters + ('author',)
        return filters

    # Custom queryset based on user
    def get_queryset(self, request):
        """Show all items for superusers, own items for others."""
        qs = super().get_queryset(request)
        if request.user.is_superuser:
            return qs
        return qs.filter(author=request.user)


