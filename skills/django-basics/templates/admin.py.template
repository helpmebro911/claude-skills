@admin.register(YourModel)
class YourModelAdmin(admin.ModelAdmin):
    """
    Full-featured admin for YourModel.
    """

    # List view configuration
    list_display = [
        'name',
        'author',
        'is_active',
        'created_at',
        'view_count_display',  # Custom method
        'actions_column',  # Custom actions
    ]

    list_filter = [
        'is_active',
        'is_featured',
        'created_at',
        ('author', admin.RelatedOnlyFieldListFilter),  # Only show authors with items
    ]

    search_fields = [
        'name',
        'description',
        'author__username',
        'author__email',
    ]

    # Ordering
    ordering = ['-created_at']

    # Date hierarchy
    date_hierarchy = 'created_at'

    # Pagination
    list_per_page = 25

    # Editable fields in list view
    list_editable = ['is_active', 'is_featured']

    # Fields shown in detail view
    fields = [
        'name',
        'slug',
        'description',
        'author',
        'is_active',
        'is_featured',
        ('created_at', 'updated_at'),  # Display side-by-side
    ]

    # Read-only fields
    readonly_fields = ['created_at', 'updated_at', 'view_count_display']

    # Auto-populate fields
    prepopulated_fields = {'slug': ('name',)}

    # Organize fields into sections
    fieldsets = (
        ('Basic Information', {
            'fields': ('name', 'slug', 'description')
        }),
        ('Relationships', {
            'fields': ('author',),
            'classes': ('collapse',)  # Collapsible section
        }),
        ('Status', {
            'fields': ('is_active', 'is_featured'),
            'description': 'Control visibility and featuring'
        }),
        ('Metadata', {
            'fields': ('created_at', 'updated_at'),
            'classes': ('collapse',)
        }),
    )

    # Filter by related fields
    autocomplete_fields = ['author']  # Requires search_fields in related admin

    # Raw ID fields (for FK/M2M with many items)
    # raw_id_fields = ['author']

    # Custom actions
    actions = ['make_active', 'make_inactive', 'mark_as_featured']

    @admin.action(description='Mark selected items as active')
    def make_active(self, request, queryset):
        """Bulk action to activate items."""
        updated = queryset.update(is_active=True)
        self.message_user(request, f'{updated} items marked as active.')

    @admin.action(description='Mark selected items as inactive')
    def make_inactive(self, request, queryset):
        """Bulk action to deactivate items."""
        updated = queryset.update(is_active=False)
        self.message_user(request, f'{updated} items marked as inactive.')

    @admin.action(description='Mark as featured')
    def mark_as_featured(self, request, queryset):
        """Bulk action to feature items."""
        updated = queryset.update(is_featured=True)
        self.message_user(request, f'{updated} items marked as featured.')

    # Custom display methods
    @admin.display(description='View Count', ordering='view_count')
    def view_count_display(self, obj):
        """Display view count with formatting."""
        if hasattr(obj, 'view_count'):
            if obj.view_count > 1000:
                return format_html('<strong>{}</strong>', obj.view_count)
            return obj.view_count
        return '-'

    @admin.display(description='Actions')
    def actions_column(self, obj):
        """Display custom action links."""
        view_url = reverse('yourapp:detail', args=[obj.slug])
        return format_html(
            '<a href="{}" target="_blank">View</a>',
            view_url
        )

    # Override queryset
    def get_queryset(self, request):
        """Optimize queryset with select_related/prefetch_related."""
        queryset = super().get_queryset(request)
        queryset = queryset.select_related('author')
        # Add annotations
        queryset = queryset.annotate(
            related_count=Count('related_items')
        )
        return queryset

    # Custom form validation
    def save_model(self, request, obj, form, change):
        """Override save to add custom logic."""
        if not change:  # Creating new object
            obj.author = request.user
        super().save_model(request, obj, form, change)


